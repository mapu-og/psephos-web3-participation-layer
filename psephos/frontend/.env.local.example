# WalletConnect Project ID (you can get one for free at https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Pinata JWT used by the Next.js server routes that upload JSON payloads to IPFS
IPFS_PINATA_JWT=

# Optional custom gateway base URL; defaults to https://gateway.pinata.cloud/ipfs
IPFS_GATEWAY_BASE_URL=https://gateway.pinata.cloud/ipfs
